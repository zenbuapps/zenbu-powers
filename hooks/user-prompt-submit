#!/usr/bin/env bash
# UserPromptSubmit hook for zenbu-powers plugin
# Injects two independent context blocks into every user turn:
#   1. Reflex dictionary (11 zenbu rules) — unconditional, always when hooks enabled
#   2. AIBDD mode prompt — conditional, only when prompt contains AIBDD/BDD/TDD trigger
#
# Both blocks are merged into a single hookSpecificOutput.additionalContext payload
# (Claude Code spec: each hook must output exactly one JSON object on stdout).
#
# Skips both blocks when user prompt contains an override keyword (e.g. 直接 / 自己來
# / 跳過 skill) indicating the user wants to bypass orchestration.
#
# Safe-fail policy: any error -> exit 0 (no JSON output, no block).
# Hook framework treats empty stdout as "no additionalContext", main flow
# proceeds normally without any injection.

set -uo pipefail

# Guard: only run when ZENBU_HOOKS_ENABLED=1 (matches session-start convention)
[ "${ZENBU_HOOKS_ENABLED:-}" != "1" ] && exit 0

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)" || exit 0
DICT_FILE="${SCRIPT_DIR}/reflex-dictionary.txt"
AIBDD_FILE="${SCRIPT_DIR}/aibdd-mode-prompt.txt"

# If reflex dictionary file missing, silently skip (reflex is the baseline; without
# it the AIBDD-only injection would be confusing and out-of-context).
[ -f "$DICT_FILE" ] || exit 0

# Read stdin (Claude Code hook standard interface)
input=$(cat 2>/dev/null) || exit 0

# Extract user prompt text
# - With jq: parse .prompt field (handles JSON escaping correctly)
# - Without jq: best-effort grep + sed (good enough for keyword detection)
if command -v jq >/dev/null 2>&1; then
    user_prompt=$(printf '%s' "$input" | jq -r '.prompt // empty' 2>/dev/null) || user_prompt=""
else
    # Fallback: extract "prompt": "..." value via sed
    # Limitation: doesn't unescape \n, \", \\ — but for keyword presence check it's sufficient
    user_prompt=$(printf '%s' "$input" | sed -n 's/.*"prompt"[[:space:]]*:[[:space:]]*"\(.*\)".*/\1/p' | head -c 8192)
fi

# Override keyword detection — if any of these substrings appear in the user prompt,
# the user has explicitly opted out of orchestration; do NOT inject reflex OR aibdd-mode.
# Pattern is OR-joined (grep -E alternation). All 11 keywords are literal substrings;
# Chinese has no word boundary issue.
override_pattern='直接|跳過 skill|不用派|不要派|自己來|就你處理|不用 sub-agent|不要 sub-agent|你做就好|不用查 skill|不用走流程'

if printf '%s' "$user_prompt" | grep -Eq "$override_pattern"; then
    # User opted out — exit cleanly, no injection
    exit 0
fi

# AIBDD trigger detection — AIBDD / BDD / TDD with strict word boundary, case-insensitive.
# Why word boundary: BDD/TDD are 3-letter tokens; substring matching would falsely fire on
#   xBDDy, subBDD, fooTDD, etc. \b ensures the token stands alone.
# Pattern explanation:
#   \b           = word boundary (left side: non-word|start)
#   (AIBDD|BDD|TDD) = the three trigger tokens
#   \b           = word boundary (right side: non-word|end)
# grep -i = case-insensitive (covers aibdd, Bdd, tdd, etc.)
# grep -E = extended regex (for | alternation and \b)
aibdd_trigger_pattern='\b(AIBDD|BDD|TDD)\b'

aibdd_active=0
if printf '%s' "$user_prompt" | grep -Eiq "$aibdd_trigger_pattern"; then
    # Trigger word matched. Confirm aibdd-mode-prompt.txt exists before activating;
    # missing file -> silent skip (reflex still injected on its own).
    [ -f "$AIBDD_FILE" ] && aibdd_active=1
fi

# Read reflex dictionary content (always required when we reach this point)
dict_content=$(cat "$DICT_FILE" 2>/dev/null) || exit 0

# Build the merged context payload.
# Spec: a single hook may only emit ONE JSON object on stdout, so reflex,
# aibdd-mode, and milestone-status must coexist within one additionalContext
# string. We separate them with blank lines so all three blocks remain distinct
# and parseable: <ZENBU_REFLEX>, <ZENBU_AIBDD_MODE>, <MILESTONE_STATUS>.
if [ "$aibdd_active" = "1" ]; then
    aibdd_content=$(cat "$AIBDD_FILE" 2>/dev/null) || aibdd_content=""
    if [ -n "$aibdd_content" ]; then
        merged_content="${dict_content}"$'\n\n'"${aibdd_content}"
    else
        merged_content="$dict_content"
    fi
else
    merged_content="$dict_content"
fi

# Milestone status injection
# Detects whether cwd has specs/milestones/STATUS.md and injects its head -40
# plus an "Active doing/:" list. Lets AI know current project state without
# user prompting. Tied to milestone-tracker skill (see references/hook-injection.md).
#
# Off-switch: ZENBU_MILESTONE_TRACKER_DISABLED=1
# Guard: file exists check prevents pollution of non-milestone projects.
#
# CWD source: prefer hook stdin .cwd (Claude Code passes it), fallback $PWD.
if [ "${ZENBU_MILESTONE_TRACKER_DISABLED:-}" != "1" ]; then
    # Determine cwd: stdin .cwd > $PWD env > error skip
    if command -v jq >/dev/null 2>&1; then
        hook_cwd=$(printf '%s' "$input" | jq -r '.cwd // empty' 2>/dev/null) || hook_cwd=""
    else
        hook_cwd=$(printf '%s' "$input" | sed -n 's/.*"cwd"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    fi
    [ -z "$hook_cwd" ] && hook_cwd="${PWD:-}"

    if [ -n "$hook_cwd" ] && [ -f "${hook_cwd}/specs/milestones/STATUS.md" ]; then
        status_head=$(head -40 "${hook_cwd}/specs/milestones/STATUS.md" 2>/dev/null) || status_head=""
        doing_list=$(ls -1 "${hook_cwd}/specs/milestones/doing/" 2>/dev/null | sed 's/^/  - /')
        if [ -n "$status_head" ]; then
            if [ -n "$doing_list" ]; then
                milestone_block=$'<MILESTONE_STATUS>\n'"$status_head"$'\n\nActive doing/:\n'"$doing_list"$'\n</MILESTONE_STATUS>'
            else
                milestone_block=$'<MILESTONE_STATUS>\n'"$status_head"$'\n\nActive doing/: (empty)\n</MILESTONE_STATUS>'
            fi
            merged_content="${merged_content}"$'\n\n'"${milestone_block}"
        fi
    fi
fi

# Emit the single JSON payload. additionalContext must be a JSON-escaped string.
if command -v jq >/dev/null 2>&1; then
    # jq path: -Rs reads raw input as a single JSON string with full escaping
    escaped=$(printf '%s' "$merged_content" | jq -Rs . 2>/dev/null) || exit 0
    # escaped already includes surrounding quotes, e.g. "<ZENBU_REFLEX>\n..."
    printf '{"hookSpecificOutput":{"hookEventName":"UserPromptSubmit","additionalContext":%s}}\n' "$escaped"
else
    # Fallback: pure bash parameter substitution (same pattern as session-start)
    s="$merged_content"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '{"hookSpecificOutput":{"hookEventName":"UserPromptSubmit","additionalContext":"%s"}}\n' "$s"
fi

exit 0
