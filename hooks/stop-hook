#!/usr/bin/env bash
# Stop hook for zenbu-powers plugin (zenbu-loop driver)
#
# ⚠️ v3.15.0 ARCHIVED: This hook is no longer registered in hooks/hooks.json.
# Every-turn evaluator validation caused excessive dialog latency; the loop
# was retired in favor of "main window completes → ship to user / opt-in
# evaluator" flow. The script file is preserved for future redesign reference.
# See hooks/stop-hook-spec.md (archived) for the historical design rationale.
#
# Architecture (post H2):
#   - This shell script handles the deterministic state-machine portion:
#     enable detection, infinite-loop guard, max-rounds escalation,
#     round_count++, dispatch reason composition.
#   - Main agent window handles evaluator dispatch (reflex rule 11).
#   - acceptance-evaluator agent handles PASS-time state reset.
#
# Output contract:
#   - Allow stop:  print "{}" (or anything that is not a "block" decision)
#   - Block stop:  print {"decision":"block","reason":"<text>"} on stdout;
#                  Claude Code feeds reason back to the main window as the
#                  next user turn. The reason carries the [ZENBU_LOOP_DISPATCH]
#                  marker so reflex rule 11 fires and dispatches the
#                  acceptance-evaluator sub-agent.
#
# Safe-fail policy: any error -> exit 0 (allow stop). Never block the main
# flow due to an internal error in the hook itself.

set -uo pipefail
trap 'exit 0' ERR

# Read the JSON payload Claude Code pipes to stdin.
input="$(cat 2>/dev/null || true)"

# === Helpers: extract fields from input JSON ===========================
# Prefer jq when available; fall back to a best-effort sed for the few
# string fields we need. The boolean stop_hook_active is also handled.

cwd=""
stop_hook_active="false"
session_id=""
transcript_path=""

if command -v jq >/dev/null 2>&1; then
    cwd=$(printf '%s' "$input" | jq -r '.cwd // empty' 2>/dev/null || true)
    stop_hook_active=$(printf '%s' "$input" | jq -r '.stop_hook_active // false' 2>/dev/null || true)
    session_id=$(printf '%s' "$input" | jq -r '.session_id // empty' 2>/dev/null || true)
    transcript_path=$(printf '%s' "$input" | jq -r '.transcript_path // empty' 2>/dev/null || true)
else
    cwd=$(printf '%s' "$input" | sed -n 's/.*"cwd"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    stop_hook_active=$(printf '%s' "$input" | sed -n 's/.*"stop_hook_active"[[:space:]]*:[[:space:]]*\([a-z]*\).*/\1/p' | head -1)
    session_id=$(printf '%s' "$input" | sed -n 's/.*"session_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    transcript_path=$(printf '%s' "$input" | sed -n 's/.*"transcript_path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
fi

cwd="${cwd:-$PWD}"
session_id="${session_id:-unknown_session}"
stop_hook_active="${stop_hook_active:-false}"

# === Step 2: stop_hook_active guard (avoid infinite recursion) =========
if [ "$stop_hook_active" = "true" ]; then
    printf '{}\n'
    exit 0
fi

# === Step 0: enable detection (Manual Loop preempts Auto Loop) =========
state_file="$cwd/.claude/zenbu-loop.local.md"
mode=""
max_rounds=10

if [ -f "$state_file" ]; then
    # Tri-state state file:
    #   status: enabled  → Manual ON
    #   status: disabled → explicit OFF (overrides env)
    #   missing/unknown  → treat as enabled (backward compat w/ legacy frontmatter)
    # Corrupt frontmatter (no leading `---`) → fall back to env detection.
    first_line=$(head -1 "$state_file" 2>/dev/null)
    if [ "$first_line" != "---" ]; then
        if [ "${ZENBU_HOOKS_ENABLED:-}" = "1" ]; then
            mode="auto"
            max_rounds=10
        else
            printf '{}\n'
            exit 0
        fi
    else
        # Strict lowercase exact match: only `disabled` triggers OFF; typos like
        # `Disabled` / `disable` / `OFF` fall through to the missing/unknown
        # branch (= enabled), avoiding silent surprise.
        status=$(grep -E '^status:' "$state_file" 2>/dev/null \
                  | head -1 \
                  | sed 's/^status:[[:space:]]*\([a-z]*\).*/\1/')
        if [ "$status" = "disabled" ]; then
            printf '{}\n'
            exit 0
        fi
        # enabled / missing / unknown → Manual mode
        mode="manual"
        mr=$(grep -E '^max_iterations:' "$state_file" 2>/dev/null \
                | head -1 \
                | sed 's/^max_iterations:[[:space:]]*\([0-9]*\).*/\1/')
        if [ -n "${mr:-}" ]; then
            max_rounds="$mr"
        fi
    fi
elif [ "${ZENBU_HOOKS_ENABLED:-}" = "1" ]; then
    mode="auto"
    max_rounds=10
else
    # Plugin not enabled in any mode - allow stop, do not run the loop.
    printf '{}\n'
    exit 0
fi

# === Step 4: max-rounds escalation =====================================
session_state_file="$HOME/.claude/data/zenbu-loop-state.json"
mkdir -p "$(dirname "$session_state_file")" 2>/dev/null || true
[ -f "$session_state_file" ] || printf '{}' > "$session_state_file"

round_count=0
if command -v jq >/dev/null 2>&1; then
    rc=$(jq -r --arg sid "$session_id" '.[$sid] // 0' "$session_state_file" 2>/dev/null || echo 0)
    case "$rc" in
        ''|*[!0-9]*) round_count=0 ;;
        *) round_count="$rc" ;;
    esac
fi

# max_rounds = 0 means "unlimited" (only applies in manual mode by spec).
if [ "$max_rounds" != "0" ] && [ "$round_count" -ge "$max_rounds" ]; then
    if [ "$mode" = "manual" ]; then
        msg="已達 max_iterations ${max_rounds} 輪未 PASS，請主 orchestrator 走升級格式回報用戶並決定續派 / 調整方向 / /zenbu-loop-cancel 取消 Manual Loop"
    else
        msg="已達 10 輪自動驗收上限，請主 orchestrator 走 10 輪 FAIL 升級格式回報用戶"
    fi
    if command -v jq >/dev/null 2>&1; then
        printf '{"systemMessage":%s}\n' "$(printf '%s' "$msg" | jq -Rs .)"
    else
        # naive escape: quotes and backslashes
        em=$(printf '%s' "$msg" | sed 's/\\/\\\\/g; s/"/\\"/g')
        printf '{"systemMessage":"%s"}\n' "$em"
    fi
    exit 0
fi

# === Step 5: extract task summary ======================================
# Manual mode: state file body (YAML frontmatter ends at second `---`)
# Auto mode:   first user message in transcript_path JSONL
task_summary=""

if [ "$mode" = "manual" ] && [ -f "$state_file" ]; then
    task_summary=$(awk '
        BEGIN { c = 0 }
        /^---[[:space:]]*$/ { c++; next }
        c >= 2 { print }
    ' "$state_file" 2>/dev/null | tr '\n' ' ' | head -c 500)
elif [ -n "$transcript_path" ] && [ -f "$transcript_path" ]; then
    if command -v jq >/dev/null 2>&1; then
        # First "user" entry's content (handles both string and array shapes).
        task_summary=$(head -50 "$transcript_path" 2>/dev/null \
            | jq -r '
                select(.type == "user")
                | .message.content
                | if type == "string" then .
                  elif type == "array" then map(select(.type=="text") | .text) | join(" ")
                  else "" end
              ' 2>/dev/null \
            | head -1 \
            | head -c 500 || true)
    else
        # crude fallback: pull first content string
        task_summary=$(head -1 "$transcript_path" 2>/dev/null \
            | sed -n 's/.*"content"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' \
            | head -c 500)
    fi
fi

if [ -z "${task_summary:-}" ]; then
    task_summary="未取得任務需求，請依當前 session 上下文推導"
fi

# === Step 6: round_count++ and write back ==============================
new_round=$((round_count + 1))

if command -v jq >/dev/null 2>&1; then
    tmp=$(mktemp 2>/dev/null || echo "$session_state_file.tmp.$$")
    if jq --arg sid "$session_id" --argjson r "$new_round" '.[$sid] = $r' \
            "$session_state_file" > "$tmp" 2>/dev/null; then
        mv "$tmp" "$session_state_file" 2>/dev/null || rm -f "$tmp" 2>/dev/null || true
    else
        rm -f "$tmp" 2>/dev/null || true
    fi
fi

# Manual mode: also mirror round_count into the state file frontmatter.
if [ "$mode" = "manual" ] && [ -f "$state_file" ]; then
    if grep -q '^round_count:' "$state_file" 2>/dev/null; then
        sed -i.bak "s/^round_count:.*/round_count: $new_round/" "$state_file" 2>/dev/null || true
        rm -f "${state_file}.bak" 2>/dev/null || true
    fi
fi

# === Step 7: compose dispatch reason ===================================
# Format defined by H2 plan; the [ZENBU_LOOP_DISPATCH] token is the
# trigger that reflex rule 11 keys on.
reason="[ZENBU_LOOP_DISPATCH] mode=${mode} session=${session_id} round=${new_round}/${max_rounds} task=${task_summary}

請依 reflex 第 11 條派 @zenbu-powers:acceptance-evaluator 對齊上述 task 進行驗收。evaluator PASS 時自行重置 ~/.claude/data/zenbu-loop-state.json 該 session_id 為 0、刪除 .claude/zenbu-loop.local.md（若存在）後才 stop。"

# Compose user-visible systemMessage (loop progress indicator).
if [ "$max_rounds" = "0" ]; then
    sysmsg_rounds="round ${new_round}/∞"
else
    sysmsg_rounds="round ${new_round}/${max_rounds}"
fi

if [ "$task_summary" = "未取得任務需求，請依當前 session 上下文推導" ]; then
    sysmsg_task="task: (未取得，依 session 上下文)"
else
    sysmsg_task="task: $(printf '%s' "$task_summary" | head -c 80)..."
fi

sysmsg="🔄 zenbu-loop [${mode}] ${sysmsg_rounds}"$'\n'"${sysmsg_task}"$'\n'"→ 派 evaluator 驗收中"

if command -v jq >/dev/null 2>&1; then
    reason_json=$(printf '%s' "$reason" | jq -Rs . 2>/dev/null)
    sysmsg_json=$(printf '%s' "$sysmsg" | jq -Rs . 2>/dev/null)
    if [ -n "${reason_json:-}" ] && [ -n "${sysmsg_json:-}" ]; then
        printf '{"decision":"block","reason":%s,"systemMessage":%s}\n' "$reason_json" "$sysmsg_json"
        exit 0
    fi
fi

# Pure-bash fallback escape (no jq).
esc="$reason"
esc="${esc//\\/\\\\}"
esc="${esc//\"/\\\"}"
esc="${esc//$'\n'/\\n}"
esc="${esc//$'\r'/\\r}"
esc="${esc//$'\t'/\\t}"

esc_sys="$sysmsg"
esc_sys="${esc_sys//\\/\\\\}"
esc_sys="${esc_sys//\"/\\\"}"
esc_sys="${esc_sys//$'\n'/\\n}"
esc_sys="${esc_sys//$'\r'/\\r}"
esc_sys="${esc_sys//$'\t'/\\t}"
printf '{"decision":"block","reason":"%s","systemMessage":"%s"}\n' "$esc" "$esc_sys"
exit 0
